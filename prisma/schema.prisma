datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id            String   @id
  name          String
  description   String?
  price         Float
  originalPrice Float?
  category      String
  images        String?
  sizes         String?
  colors        String?
  rating        Float    @default(5.0)
  stock         Int      @default(10)
  isFeatured    Int      @default(0)
  dateAdded     String?
  reviews       Review[]

  @@map("products")
}

model Review {
  id           String  @id
  productId    String
  reviewerName String
  rating       Float
  comment      String?
  date         String?
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Customer {
  id            String   @id
  email         String   @unique
  passwordHash  String
  name          String
  phone         String?
  isVerified    Int      @default(0)
  createdAt     String
  orders        Order[]

  @@map("customers")
}

model Category {
  id        String @id
  name      String @unique
  slug      String @unique
  image     String?
  sortOrder Int    @default(0)
  isActive  Int    @default(1)

  @@map("categories")
}

model EmailOtp {
  id        String @id
  email     String
  code      String
  purpose   String
  expiresAt String
  createdAt String

  @@map("email_otps")
}

model Order {
  id              String  @id
  customerId      String?
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  city            String
  postalCode      String
  items           String
  subtotal        Float
  discount        Float   @default(0)
  total           Float
  currency        String  @default("USD")
  paymentMethod   String
  paymentStatus   String
  status          String
  date            String
  notes           String?
  paymentRef      String?
  customer        Customer? @relation(fields: [customerId], references: [id])

  @@map("orders")
}

model Coupon {
  code         String @id
  discountType String
  value        Float
  minPurchase  Float  @default(0)
  isActive     Int    @default(1)

  @@map("coupons")
}
