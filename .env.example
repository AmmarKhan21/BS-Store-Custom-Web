# ADMIN_USERNAME: Login username for the merchant dashboard (default: admin)
ADMIN_USERNAME="admin"

# ADMIN_PASSWORD: Login password for the merchant dashboard. Change this in production!
ADMIN_PASSWORD="bismillah-admin-change-me"

# CUSTOMER_SESSION_SECRET: Secret for customer login tokens
# CUSTOMER_SESSION_SECRET="your-customer-secret"

# CURRENCY: USD to PKR exchange rate for price display
PKR_EXCHANGE_RATE=280

# EMAIL (for OTP + order notifications — use Gmail app password for testing)
# Without these, emails print to server console in dev mode
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=your-email@gmail.com
ADMIN_ORDER_EMAIL=your-email@gmail.com

# PayFast Pakistan (gopayfast.com) — leave empty for sandbox mock redirect
PAYFAST_MERCHANT_ID=
PAYFAST_SECURED_KEY=
PAYFAST_MERCHANT_NAME=Bismillah Store
PAYFAST_SANDBOX=true

# JazzCash — leave empty for sandbox mock redirect
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_SANDBOX=true

# LOW_STOCK_THRESHOLD: Alert when product stock falls to this level or below (default: 5)
LOW_STOCK_THRESHOLD=5

# WhatsApp notifications — admin + customer on new orders
#
# OPTION A — Admin only (free, easy):
#   1. Message CallMeBot on WhatsApp to get your API key: https://www.callmebot.com/blog/free-api-whatsapp-messages/
#   2. Set your number below (Pakistan: 923001234567)
WHATSAPP_ADMIN_PHONE=923001234567
CALLMEBOT_API_KEY=
#
# OPTION B — Customer + admin auto-messages (recommended for production):
#   Meta WhatsApp Cloud API — https://developers.facebook.com/docs/whatsapp/cloud-api
#   Create templates in Meta Business Manager:
#     order_confirmation: "Hello {{1}}, order {{2}} confirmed. Items: {{3}}. Total: {{4}}. Thank you!"
#     order_shipped: "Hello {{1}}, order {{2}} shipped. Tracking: {{3}}."
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ORDER_TEMPLATE=order_confirmation
WHATSAPP_SHIPPED_TEMPLATE=order_shipped

# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Supabase transaction pooler (port 6543) for the running app.
# Encode special chars in password (@ → %40, # → %23, etc.)
# Example: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# DIRECT_URL: Supabase session/direct connection (port 5432) for prisma db push / migrations.
# Example: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
DIRECT_URL=
